// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum GuildRole {
  MEMBER
  MODERATOR
  ADMIN
  OWNER
}

model Role {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]       @relation("UserRoles")

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String   @unique
  description String?
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  email         String    @unique
  username      String    @unique
  password      String
  firstName     String
  lastName      String
  bio           String?
  location      String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  walletAddress String?   @unique
  refreshToken  String?

  // Profile fields
  profileBio    String?
  profileUrl    String?
  discordHandle String?
  twitterHandle String?
  githubHandle  String?
  backgroundCid String?

  // Profile completion tracking
  hasCompletionBonus Boolean @default(false)
  xp                 Int     @default(0)
  totalViews         Int     @default(0)

  // Notification preferences
  notificationSettings Json? @default("{\"emailOnBounty\":true,\"emailOnMention\":true,\"weeklyDigest\":true}")

  // Relations
  ownedGuilds        Guild[]             @relation("UserOwnerGuilds")
  joinedGuilds       GuildMembership[]   @relation("UserJoinedGuilds")
  invitedMemberships GuildMembership[]   @relation("UserInvitedMemberships")
  createdBounties    Bounty[]            @relation("UserCreatedBounties")
  assignedBounties   Bounty[]            @relation("UserAssignedBounties")
  roles              Role[]              @relation("UserRoles")
  followers          Follow[]            @relation("Follower")
  following          Follow[]            @relation("Following")
  messagesSent       Message[]           @relation("MessagesSent")
  messagesReceived   Message[]           @relation("MessagesReceived")
  forumThreads       ForumThread[]
  forumPosts         ForumPost[]
  notifications      Notification[]
  privacySettings    PrivacySettings?
  bountyApplications BountyApplication[]
  bountyPayouts      BountyPayout[]
  apiKeys            ApiKey[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
}

model Guild {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  ownerId     String
  settings    Json?
  memberCount Int       @default(1)
  isActive    Boolean   @default(true)

  // Relations
  owner       User              @relation("UserOwnerGuilds", fields: [ownerId], references: [id])
  memberships GuildMembership[]
  bounties    Bounty[]          @relation("GuildBounties")

  @@index([ownerId])
  @@index([isActive])
  @@index([createdAt])
  @@map("guilds")
}

model GuildMembership {
  id                  String           @id @default(cuid())
  createdAt           DateTime         @default(now())
  joinedAt            DateTime         @default(now())
  status              MembershipStatus @default(APPROVED)
  invitationToken     String?
  invitedById         String?
  invitationExpiresAt DateTime?
  role                GuildRole        @default(MEMBER)
  bio                 String?
  userId              String
  guildId             String

  // Relations
  user  User  @relation("UserJoinedGuilds", fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  invitedBy User? @relation("UserInvitedMemberships", fields: [invitedById], references: [id])

  //  REVOKED
  @@unique([userId, guildId])
  @@index([status])
  @@index([guildId])
  @@index([userId])
  @@map("guild_memberships")
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

model Bounty {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  title        String
  description  String
  status       String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED
  rewardAmount Decimal
  rewardToken  String    @default("STELLAR")
  deadline     DateTime?
  creatorId    String
  assigneeId   String?
  guildId      String?
  reminderSent Boolean   @default(false)

  // Relations
  creator      User                @relation("UserCreatedBounties", fields: [creatorId], references: [id])
  assignee     User?               @relation("UserAssignedBounties", fields: [assigneeId], references: [id])
  guild        Guild?              @relation("GuildBounties", fields: [guildId], references: [id])
  applications BountyApplication[]
  milestones   BountyMilestone[]
  payouts      BountyPayout[]

  @@index([guildId])
  @@index([status])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([status, guildId])
  @@map("bounties")
}

model BountyApplication {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bountyId      String
  applicantId   String
  message       String?
  attachments   Json?
  status        String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, WITHDRAWN
  reviewerId    String?
  reviewMessage String?

  bounty    Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  applicant User   @relation(fields: [applicantId], references: [id])

  @@index([bountyId])
  @@index([applicantId])
  @@index([status])
  @@map("bounty_applications")
}

model BountyMilestone {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bountyId    String
  title       String
  description String?
  amount      Decimal
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING, COMPLETE, APPROVED, REJECTED
  completedAt DateTime?

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@index([bountyId])
  @@index([status])
  @@map("bounty_milestones")
}

model BountyPayout {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  bountyId    String
  toUserId    String
  amount      Decimal
  token       String    @default("STELLAR")
  txRef       String?
  status      String    @default("PENDING") // PENDING, SENT, FAILED
  processedAt DateTime?

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  toUser User   @relation(fields: [toUserId], references: [id])

  @@index([bountyId])
  @@index([toUserId])
  @@index([status])
  @@map("bounty_payouts")
}

// social / community tables

model Follow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String

  @@unique([followerId, followingId])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  from      User     @relation("MessagesSent", fields: [fromId], references: [id], onDelete: Cascade)
  fromId    String
  to        User     @relation("MessagesReceived", fields: [toId], references: [id], onDelete: Cascade)
  toId      String
  body      String
  encrypted Boolean  @default(false)
  read      Boolean  @default(false)

  @@index([fromId])
  @@index([toId])
  @@index([read])
  @@index([createdAt])
}

model ForumThread {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  title     String
  creator   User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String
  posts     ForumPost[]

  @@index([creatorId])
  @@index([createdAt])
}

model ForumPost {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  editedAt  DateTime?

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  message   String
  read      Boolean  @default(false)
  type      String?
  metadata  Json?

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
}

model PrivacySettings {
  id                            String  @id @default(cuid())
  user                          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                        String  @unique
  showActivityFeed              Boolean @default(true)
  allowMessagesFromNonFollowers Boolean @default(false)
  showAchievements              Boolean @default(true)
}

model TreasuryTransaction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  guildId     String
  amount      Decimal
  asset       String
  fromAddress String
  toAddress   String
  txHash      String   @unique
  timestamp   DateTime

  @@index([guildId])
  @@index([txHash])
  @@map("treasury_transactions")
}

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  keyHash   String   @unique
  label     String?
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}
